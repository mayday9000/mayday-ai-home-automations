# Lead-intake endpoint that triggers the AI callback (JSON POST). Leave unset to stub locally.
LEAD_WEBHOOK_URL=https://app.maydayautomation.com/api/webhooks/lead-intake

# Shared secret sent as the x-lead-intake-secret header. Server-side only —
# never expose in browser code or commit the real value.
LEAD_INTAKE_SECRET=

# Neon Postgres connection string (pooled). Used for leads, SMS consents, unsubscribes.
# Leave unset locally — API routes log and degrade gracefully outside production.
DATABASE_URL=
